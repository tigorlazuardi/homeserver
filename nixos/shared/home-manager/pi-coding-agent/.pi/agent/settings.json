{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "kimi-coding",
  "defaultModel": "kimi-for-coding",
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:pi-rtk-optimizer",
    {
      "source": "npm:@pi-unipi/unipi",
      "extensions": [
        "+node_modules/@pi-unipi/footer/src/index.ts"
      ]
    },
    {
      "source": "git:github.com/rytswd/pi-agent-extensions",
      "extensions": [
        "-fetch/index.ts",
        "-notify/index.ts",
        "-permission-gate/index.ts",
        "-questionnaire/index.ts",
        "-slow-mode/index.ts",
        "-statusline/index.ts",
        "-stash/index.ts"
      ]
    },
    "npm:pi-hashline-readmap",
    "npm:@dreki-gg/pi-context7"
  ],
  "editorPaddingX": 1,
  "doubleEscapeAction": "tree",
  "extensions": [
    "+extensions/pi-telegram-multi/index.ts"
  ],
  "unipi": {
    "info": {
      "showOnBoot": false,
      "bootTimeoutMs": 8000,
      "groups": {
        "overview": {
          "show": true
        }
      }
    },
    "footer": {
      "enabled": true,
      "preset": "default",
      "separator": "powerline",
      "iconStyle": "nerd",
      "zoneSeparator": "·",
      "showFullLabels": false,
      "groups": {
        "core": {
          "show": true,
          "segments": {
            "model": true,
            "api_state": true,
            "tool_count": true,
            "git": true
          }
        },
        "compactor": {
          "show": true,
          "segments": {}
        },
        "memory": {
          "show": true,
          "segments": {}
        },
        "mcp": {
          "show": true,
          "segments": {}
        },
        "ralph": {
          "show": true,
          "segments": {}
        },
        "workflow": {
          "show": true,
          "segments": {}
        },
        "kanboard": {
          "show": true,
          "segments": {}
        },
        "notify": {
          "show": false,
          "segments": {}
        },
        "status_ext": {
          "show": true,
          "segments": {}
        }
      }
    }
  }
}