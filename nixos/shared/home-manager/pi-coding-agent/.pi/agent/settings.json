{
  "lastChangelogVersion": "0.74.0",
  "defaultProvider": "kimi-coding",
  "defaultModel": "kimi-for-coding",
  "defaultThinkingLevel": "medium",
  "packages": [
    "npm:pi-rtk-optimizer",
    "npm:@pi-unipi/unipi",
    {
      "source": "git:github.com/rytswd/pi-agent-extensions",
      "extensions": [
        "-fetch/index.ts",
        "-notify/index.ts",
        "-permission-gate/index.ts",
        "-questionnaire/index.ts",
        "-slow-mode/index.ts",
        "-statusline/index.ts",
        "-stash/index.ts"
      ]
    }
  ],
  "editorPaddingX": 1,
  "doubleEscapeAction": "tree",
  "extensions": [
    "+extensions/pi-telegram-multi/index.ts"
  ],
  "unipi": {
    "info": {
      "showOnBoot": false,
      "bootTimeoutMs": 8000,
      "groups": {
        "overview": {
          "show": true
        }
      }
    }
  }
}
